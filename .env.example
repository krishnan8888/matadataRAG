# Local defaults
HOST=127.0.0.1
PORT=8000
RELOAD=0

# Set to 0.0.0.0 when running inside a container or remote host.
# HOST=0.0.0.0

# Comma-separated frontend origins when the API and frontend are deployed separately.
# CORS_ORIGINS=https://example.com,https://admin.example.com

# Maximum uploaded file size in bytes. Default: 25 MB.
# MAX_UPLOAD_BYTES=26214400

# Model configuration
OLLAMA_BASE_URL=http://127.0.0.1:11434
METADATA_MODEL=qwen2.5-coder:7b
ANSWER_MODEL=qwen2.5-coder:7b
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
OLLAMA_KEEP_ALIVE=30m
LOCAL_SHUTDOWN_ENABLED=true
